{{- define "writeto" -}}
func (s *{{.StructName}}) WriteTo(w io.Writer) (n int64, err error) {
{{- $first := true }}
{{- range .Fields }}
    {{- if $first }}
    nn, err := s.{{ .Name }}.WriteTo(w)
    {{- $first = false }}
    {{- else }}
    nn, err = s.{{ .Name }}.WriteTo(w)
    {{- end }}
    if err != nil {
        return n, err
    }
    n += nn
{{- end }}
    return n, nil
}

{{ end -}}
